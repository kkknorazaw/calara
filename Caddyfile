:80 {
    root * /var/www/wan
    encode gzip zstd

    @next path /_next/static/*
    header @next Cache-Control "public, max-age=31536000, immutable"

    @html path_regexp html \.html$
    header @html Cache-Control "public, max-age=300"

    try_files {path} {path}/ {path}.html /index.html
    file_server
}
